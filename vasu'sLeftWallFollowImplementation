#include <Wire.h>

#define MPU_ADDR    0x69
#define PWR_MGMT_1  0x6B
#define GYRO_CONFIG 0x1B
#define GYRO_ZOUT_H 0x47

float leftDist = 10.0, rightDist = 10.0, frontDist = 10.0; // Last known distances
unsigned long lastPingTime = 0;
int sensorTurn = 0; // 0=Left, 1=Right, 2=Front

const int PING_INTERVAL = 20; // Wait 15ms between pings so echoes die out

// === Ultrasonic pins ===
int trigf = 12, echof = 11;
int trigr = 9,  echor = 8;
int trigl = 13, echol = 10;

// === Motor pins ===
int in1 = 5;
int in2 = 7;
int in3 = 4;
int in4 = 2;
int PWMA = 6;   // PWM - left
int PWMB = 3;   // PWM - right

// === Encoder Pins ===
#define LEFT_A   A0
#define LEFT_B   A1
#define RIGHT_A  A2
#define RIGHT_B  A3

// === Speeds & Limits ===
const int baseSpeed   = 120; 
const int maxSpeed    = 150; 
const int turnPWM     = 38;  
const int PWM_DEADBAND = 30; 

const float LEFT_SCALE  = 1.00; 
const float RIGHT_SCALE = 1.00;

// === Maze & Movement params ===
const int sideOpenThresh = 18;  // cm to consider cell opening
const int stopFront      = 8;   // cm hard stop to avoid collision
const int corridorThresh = 12;
const long TICKS_HALF_CELL = 150; // For 20cm cells, 44mm wheels, 300PPR

// === PID & Fusion Gains ===
float Kp = 1.824, Ki = 0.001, Kd = 0.44;
float K_wall = 1.0; 
float K_yaw  = 0.9; // Tune: higher means it prioritizes staying straight over centering

float integ = 0;
float lastErr = 0;
unsigned long lastPID = 0;
const int integralLimit = 200; 

// === State Variables ===
volatile long leftCount = 0;
volatile long rightCount = 0;
uint8_t lastPortC;

float currentYaw = 0.0;
unsigned long lastYawTime = 0;
float gzBias = 0.0f;
const float ANGLE_TOL = 3.0f; 

// -------------------- PCINT Encoder ISR --------------------
ISR(PCINT1_vect) {
  uint8_t currentPortC = PINC;
  uint8_t changed = currentPortC ^ lastPortC;

  // LEFT MOTOR
  if (changed & (1 << PC0)) {
    bool A = currentPortC & (1 << PC0);
    if (A) {  
      bool B = currentPortC & (1 << PC1);
      if (B) leftCount--;
      else   leftCount++;
    }
  }
  
  // RIGHT MOTOR
  if (changed & (1 << PC2)) {
    bool A = currentPortC & (1 << PC2);
    if (A) {  
      bool B = currentPortC & (1 << PC3);
      if (B) rightCount++;
      else   rightCount--;
    }
  }
  lastPortC = currentPortC;
}

// -------------------- MPU & Gyro --------------------
static inline int16_t readGyroZRaw() {
  Wire.beginTransmission(MPU_ADDR);
  Wire.write(GYRO_ZOUT_H);
  Wire.endTransmission(false);
  Wire.requestFrom(MPU_ADDR, 2, true);
  int16_t gz_raw = (Wire.read() << 8) | Wire.read();
  return gz_raw;
}

float readGyroZ() {
  return (readGyroZRaw() / 131.0f) - gzBias;
}

void initMPU() {
  Wire.beginTransmission(MPU_ADDR);
  Wire.write(PWR_MGMT_1);
  Wire.write(0x00);
  Wire.endTransmission();

  Wire.beginTransmission(MPU_ADDR);
  Wire.write(GYRO_CONFIG);
  Wire.write(0x00);
  Wire.endTransmission();
}

void calibrateGyroZ(uint16_t samples = 500) {
  delay(300);
  long sum = 0;
  for (uint16_t i = 0; i < samples; i++) {
    sum += readGyroZRaw();
    delay(2);
  }
  gzBias = (sum / (float)samples) / 131.0f; 
}

void updateYaw() {
  unsigned long now = millis();
  float dt = (now - lastYawTime) / 1000.0f;
  lastYawTime = now;
  if (dt > 0 && dt < 0.1) { 
      currentYaw += readGyroZ() * dt;
  }
}

// -------------------- Ultrasound --------------------
float getDistanceSafe(int trig, int echo) {
  digitalWrite(trig, LOW);  delayMicroseconds(2);
  digitalWrite(trig, HIGH); delayMicroseconds(10);
  digitalWrite(trig, LOW);
  
  // 5000us timeout prevents freezing, but guarantees we wait for the echo
  long duration = pulseIn(echo, HIGH, 5000); 
  if (duration == 0) return 1000; 
  return duration * 0.034 / 2; 
}

