// -------------------- Motion Primitives --------------------
void stopMotors() {
  digitalWrite(in1, LOW); digitalWrite(in2, LOW);
  digitalWrite(in3, LOW); digitalWrite(in4, LOW);
  analogWrite(PWMA, 0);   analogWrite(PWMB, 0);
}

void setInPlaceRight() {
  digitalWrite(in1, HIGH); digitalWrite(in2, LOW);
  digitalWrite(in3, LOW);  digitalWrite(in4, HIGH);
}

void setInPlaceLeft() {
  digitalWrite(in1, LOW);  digitalWrite(in2, HIGH);
  digitalWrite(in3, HIGH); digitalWrite(in4, LOW);
}

void driveMotors(int left, int right) {
  float lf = left  * LEFT_SCALE;
  float rf = right * RIGHT_SCALE;

  if (lf > 0 && lf < PWM_DEADBAND) lf = PWM_DEADBAND;
  if (lf < 0 && lf > -PWM_DEADBAND) lf = -PWM_DEADBAND;
  if (rf > 0 && rf < PWM_DEADBAND) rf = PWM_DEADBAND;
  if (rf < 0 && rf > -PWM_DEADBAND) rf = -PWM_DEADBAND;

  lf = constrain((int)lf, -255, 255);
  rf = constrain((int)rf, -255, 255);

  if (lf >= 0) { digitalWrite(in1, HIGH); digitalWrite(in2, LOW);  }
  else         { digitalWrite(in1, LOW);  digitalWrite(in2, HIGH); }

  if (rf >= 0) { digitalWrite(in3, HIGH); digitalWrite(in4, LOW);  }
  else         { digitalWrite(in3, LOW);  digitalWrite(in4, HIGH); }

  analogWrite(PWMA, abs((int)lf));
  analogWrite(PWMB, abs((int)rf));
}

// -------------------- Precise Control Functions --------------------
void resetPID() {
  integ = 0;
  lastErr = 0;
  currentYaw = 0; 
  lastYawTime = millis();
  lastPID = millis();
}

void driveTicksStraight(long targetTicks) {
  noInterrupts();
  leftCount = 0;
  rightCount = 0;
  interrupts();
  
  currentYaw = 0; 
  lastYawTime = millis();
  
  while (true) {
    noInterrupts();
    long currentL = abs(leftCount); 
    long currentR = abs(rightCount);
    interrupts();

    if ((currentL + currentR) / 2 >= targetTicks) break;

    updateYaw();
    float correction = currentYaw * 2.0; 
    driveMotors(baseSpeed + (int)correction, baseSpeed - (int)correction);
  }
  stopMotors(); 
}

void turnByAngle(float targetAngleDeg) {
  currentYaw = 0;
  lastYawTime = millis();

  // -90 is Left, +90 is Right
  if (targetAngleDeg < 0) {
    setInPlaceLeft();
  } else {
    setInPlaceRight();
  }
  
  analogWrite(PWMA, turnPWM);
  analogWrite(PWMB, turnPWM);

  float targetAbs = fabs(targetAngleDeg);

  while (true) {
    updateYaw();
    
    // By using absolute value, we don't care if the gyro reads -90 or +90.
    // We just care that it has traveled 90 degrees total!
    float yawTraveled = fabs(currentYaw);
    
    if (yawTraveled >= targetAbs - ANGLE_TOL) {
      break;
    }
  }
  stopMotors();
}
void driveUntilWallsDetected() {
  currentYaw = 0; 
  lastYawTime = millis();
  
  while (true) {
    // Keep polling the sensors in the background without delays
    // updateSensors(); 
    
    // Break if both walls return, or if front wall approaches
    // Notice we use the globals now!
    if ((leftDist < corridorThresh && rightDist < corridorThresh) || frontDist < stopFront) {
      break;
    }

    updateYaw();
    float correction = currentYaw * 2.0; 
    driveMotors(baseSpeed + (int)correction, baseSpeed - (int)correction);
  }
  resetPID(); 
}

// -------------------- Standard PID --------------------
void PID_step() {
  // NO delays or getDistance calls here anymore!
  // We just trust the leftDist and rightDist globals.
  
  updateYaw(); 
  
  float err = 0;
  float idealDist = corridorThresh / 2.0; 
  
  if (leftDist < corridorThresh && rightDist < corridorThresh) {
      err = rightDist - leftDist;
  } 
  else if (leftDist < corridorThresh) {
      float wallErr = idealDist - leftDist;
      err = (wallErr * K_wall) - (currentYaw * K_yaw);
  } 
  else if (rightDist < corridorThresh) {
      float wallErr = rightDist - idealDist;
      err = (wallErr * K_wall) - (currentYaw * K_yaw);
  } 
  else {
      err = -currentYaw * K_yaw;
  }

  unsigned long now = millis();
  float dt = (now - lastPID) / 1000.0f;
  lastPID = now;
  if (dt <= 0) dt = 0.05;

  integ += err * dt;
  integ = constrain(integ, -100.0f, 100.0f);
  float deriv = (err - lastErr) / dt;
  float corr  = Kp*err + Ki*integ + Kd*deriv;
  lastErr = err;

  int leftSpeed  = baseSpeed - (int)corr;
  int rightSpeed = baseSpeed + (int)corr;

  driveMotors(leftSpeed, rightSpeed);
}

// -------------------- Arduino Setup & Loop --------------------
void setup() {
  Serial.begin(115200);

  pinMode(trigf, OUTPUT); pinMode(echof, INPUT);
  pinMode(trigl, OUTPUT); pinMode(echol, INPUT);
  pinMode(trigr, OUTPUT); pinMode(echor, INPUT);

  pinMode(in1, OUTPUT); pinMode(in2, OUTPUT);
  pinMode(in3, OUTPUT); pinMode(in4, OUTPUT);
  pinMode(PWMA, OUTPUT); pinMode(PWMB, OUTPUT);

  // Setup PCINT Encoders
  pinMode(LEFT_A, INPUT_PULLUP);  pinMode(LEFT_B, INPUT_PULLUP);
  pinMode(RIGHT_A, INPUT_PULLUP); pinMode(RIGHT_B, INPUT_PULLUP);

  PCICR |= (1 << PCIE1);
  PCMSK1 |= (1 << PCINT8) | (1 << PCINT9) | (1 << PCINT10) | (1 << PCINT11);
  lastPortC = PINC;

  Wire.begin();
  initMPU();
  calibrateGyroZ(500); // KEEP STILL
  
  resetPID();
}

void loop() {
  // Update the GLOBAL variables so PID_step() can actually see them!
  leftDist  = getDistanceSafe(trigl, echol); delay(15);
  rightDist = getDistanceSafe(trigr, echor); delay(15);
  frontDist = getDistanceSafe(trigf, echof); delay(15);

  // 1. LEFT OPEN
  if (leftDist > sideOpenThresh) {
    driveTicksStraight(TICKS_HALF_CELL); // Move to center
    stopMotors(); delay(50);             // Brief mechanical settle, no revving
    
    turnByAngle(90.0); // NOTE: In my last code this was -90 for Left. Ensure your signs match your physical bot!
    stopMotors(); delay(50);
    
    // CRITICAL: Drive completely out of the cell + 100 ticks extra to clear the sensor blindspot
    driveTicksStraight(TICKS_HALF_CELL + 100); 
    
    resetPID();
    return;
  }
  
  // 2. FRONT CLEAR (Straight Corridor)
  else if (frontDist > stopFront) {
    PID_step();
  }
  
  // 3. RIGHT OPEN
  else if (rightDist > sideOpenThresh) {
    // driveTicksStraight(TICKS_HALF_CELL); 
    stopMotors(); delay(50);
    
    turnByAngle(-90.0);
    stopMotors(); delay(50);
    
    driveTicksStraight(TICKS_HALF_CELL + 100); 
    
    resetPID();
    return;
  }
  
  // 4. DEAD END
  else {
    stopMotors(); delay(50);
    turnByAngle(180.0f);
    stopMotors(); delay(50);
    
    // Get out of the dead end cell before checking sensors again
    driveTicksStraight(TICKS_HALF_CELL + 100); 
    resetPID();
  }
}
